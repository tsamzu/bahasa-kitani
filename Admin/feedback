<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Feedback Manager — Bahasa Kitani</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;1,600&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{--bg:#F8F5F0;--surface:#FFF;--border:#E4DDD3;--text:#1A1714;--muted:#A8998E;--sub:#6B6158;--accent:#C4622D;--accent-l:#FAE9DE;--accent-d:#9E4B20;--green:#3D6B5E;--green-l:#DFF0EB;--red:#B83232;--red-l:#FAEAEA;--r:12px}
    body{font-family:'Outfit',sans-serif;background:var(--bg);color:var(--text);min-height:100vh}
    header{background:var(--surface);border-bottom:1px solid var(--border);height:56px;display:flex;align-items:center;justify-content:space-between;padding:0 2rem}
    .logo{font-family:'Playfair Display',serif;font-size:1rem}
    .logo span{color:var(--accent);font-style:italic}
    .back-btn{font-size:0.8rem;color:var(--sub);text-decoration:none;display:flex;align-items:center;gap:0.35rem;transition:color .15s}
    .back-btn:hover{color:var(--accent)}
    .wrap{max-width:900px;margin:0 auto;padding:2rem 1.5rem}
    h1{font-family:'Playfair Display',serif;font-size:1.5rem;margin-bottom:0.3rem}
    .page-sub{font-size:0.85rem;color:var(--muted);margin-bottom:1.5rem;line-height:1.6}
    .info-box{background:var(--accent-l);border:1px solid #EDD0BC;border-radius:var(--r);padding:1.1rem 1.25rem;margin-bottom:1.5rem;font-size:0.82rem;color:var(--accent-d);line-height:1.65}
    .info-box strong{font-weight:600}
    .info-box ol{margin-left:1.1rem;margin-top:0.4rem}
    .info-box li{margin-bottom:0.2rem}
    .filters{display:flex;gap:0.4rem;flex-wrap:wrap;margin-bottom:1.1rem}
    .ftab{padding:0.3rem 0.8rem;border-radius:999px;border:1.5px solid var(--border);background:var(--surface);font-family:'Outfit',sans-serif;font-size:0.76rem;font-weight:500;color:var(--sub);cursor:pointer;transition:all .15s}
    .ftab:hover{border-color:var(--accent);color:var(--accent)}
    .ftab.active{background:var(--accent);border-color:var(--accent);color:#fff}
    .stats-row{display:flex;gap:1rem;flex-wrap:wrap;margin-bottom:1.25rem}
    .stat-pill{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:0.5rem 0.9rem;display:flex;align-items:baseline;gap:0.35rem}
    .stat-n{font-family:'Playfair Display',serif;font-size:1.2rem;color:var(--accent);font-weight:700}
    .stat-l{font-size:0.72rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.07em}
    .fb-list{display:flex;flex-direction:column;gap:0.75rem}
    .fb-item{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:1.1rem 1.25rem;display:grid;grid-template-columns:1fr auto;gap:1rem;align-items:start}
    .fb-item.resolved{opacity:.55;border-style:dashed}
    .fb-meta{display:flex;align-items:center;gap:0.6rem;flex-wrap:wrap;margin-bottom:0.5rem}
    .fb-type-tag{font-size:0.63rem;font-weight:700;letter-spacing:0.07em;text-transform:uppercase;padding:0.18rem 0.5rem;border-radius:4px}
    .type-correction{background:#FAEAEA;color:var(--red)}
    .type-new-word{background:var(--green-l);color:var(--green)}
    .type-dialect{background:#EDE8F5;color:#5C4A7C}
    .type-general{background:#EDE9E2;color:var(--muted)}
    .fb-name{font-size:0.8rem;font-weight:600;color:var(--text)}
    .fb-email{font-size:0.75rem;color:var(--muted)}
    .fb-date{font-size:0.72rem;color:var(--muted);margin-left:auto}
    .fb-message{font-size:0.85rem;color:var(--sub);line-height:1.6;margin-bottom:0.65rem}
    .fb-actions{display:flex;gap:0.4rem;flex-direction:column}
    .action-btn{padding:0.4rem 0.75rem;border-radius:7px;border:1.5px solid var(--border);background:none;font-family:'Outfit',sans-serif;font-size:0.75rem;font-weight:500;cursor:pointer;transition:all .15s;white-space:nowrap}
    .action-btn.resolve{border-color:var(--green);color:var(--green)}
    .action-btn.resolve:hover{background:var(--green);color:#fff}
    .action-btn.delete{border-color:var(--red);color:var(--red)}
    .action-btn.delete:hover{background:var(--red);color:#fff}
    .action-btn.restore{border-color:var(--sub);color:var(--sub)}
    .action-btn.restore:hover{background:var(--bg);color:var(--text)}
    .empty-state{text-align:center;padding:3rem 1rem;color:var(--muted)}
    .empty-state h3{font-family:'Playfair Display',serif;font-size:1.2rem;margin-bottom:0.4rem;color:var(--sub)}
    /* Add form */
    .add-form{background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:1.25rem;margin-bottom:1.5rem}
    .add-form h3{font-family:'Playfair Display',serif;font-size:1rem;margin-bottom:0.85rem}
    .form-row{display:grid;grid-template-columns:1fr 1fr 1fr auto;gap:0.6rem;align-items:end}
    .fg{display:flex;flex-direction:column;gap:0.28rem}
    .fg label{font-size:0.65rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--muted)}
    .fg input,.fg select,.fg textarea{padding:0.6rem 0.8rem;border:1.5px solid var(--border);border-radius:8px;font-family:'Outfit',sans-serif;font-size:0.84rem;color:var(--text);background:var(--bg);outline:none;transition:border-color .2s,box-shadow .2s}
    .fg input:focus,.fg select:focus,.fg textarea:focus{border-color:var(--accent);box-shadow:0 0 0 3px var(--accent-l)}
    .fg textarea{resize:vertical;min-height:80px;grid-column:1/-1}
    .btn{padding:0.65rem 1.1rem;border-radius:8px;font-family:'Outfit',sans-serif;font-size:0.84rem;font-weight:600;cursor:pointer;border:none;transition:all .2s}
    .btn-primary{background:var(--accent);color:#fff;height:fit-content}
    .btn-primary:hover{background:var(--accent-d)}
    .resolved-badge{font-size:0.65rem;font-weight:700;text-transform:uppercase;letter-spacing:0.07em;background:var(--green-l);color:var(--green);padding:0.15rem 0.45rem;border-radius:4px}
    @media(max-width:600px){.form-row{grid-template-columns:1fr}.fb-item{grid-template-columns:1fr}.fb-actions{flex-direction:row}}
  </style>
</head>
<body>

<header>
  <div class="logo">Bahasa Kitani — <span>Feedback Manager</span></div>
  <a class="back-btn" href="../index.html">← Back to website</a>
</header>

<div class="wrap">
  <h1>Feedback Manager</h1>
  <p class="page-sub">Review, manage and act on feedback submitted by visitors. All data is stored in your browser (localStorage) on this device.</p>

  <div class="info-box">
    <strong>How feedback reaches you:</strong>
    <ol>
      <li>When a visitor submits feedback on the website, it opens their email app with your address pre-filled</li>
      <li>You receive it at <strong>izz.zu@icloud.com</strong></li>
      <li>You can then manually paste it here using the "Add Feedback Entry" form below to track and manage it</li>
      <li>Mark entries as Resolved once you've acted on them (e.g. added the word to the dictionary)</li>
    </ol>
  </div>

  <!-- STATS -->
  <div class="stats-row">
    <div class="stat-pill"><span class="stat-n" id="stat-total">0</span><span class="stat-l">Total</span></div>
    <div class="stat-pill"><span class="stat-n" id="stat-open">0</span><span class="stat-l">Open</span></div>
    <div class="stat-pill"><span class="stat-n" id="stat-resolved">0</span><span class="stat-l">Resolved</span></div>
  </div>

  <!-- ADD ENTRY FORM -->
  <div class="add-form">
    <h3>➕ Add Feedback Entry</h3>
    <div class="form-row">
      <div class="fg"><label>Name</label><input type="text" id="a-name" placeholder="Sender name" /></div>
      <div class="fg"><label>Email</label><input type="text" id="a-email" placeholder="Sender email" /></div>
      <div class="fg"><label>Type</label>
        <select id="a-type">
          <option value="correction">Correction</option>
          <option value="new-word">New Word</option>
          <option value="dialect">Dialect Variant</option>
          <option value="general">General</option>
        </select>
      </div>
      <button class="btn btn-primary" onclick="addEntry()">Add</button>
    </div>
    <div class="form-row" style="margin-top:0.6rem;grid-template-columns:1fr">
      <div class="fg"><label>Message</label><textarea id="a-message" placeholder="Paste the feedback message here..."></textarea></div>
    </div>
  </div>

  <!-- FILTERS -->
  <div class="filters">
    <button class="ftab active" onclick="setFilter('all',this)">All</button>
    <button class="ftab" onclick="setFilter('open',this)">Open</button>
    <button class="ftab" onclick="setFilter('resolved',this)">Resolved</button>
    <button class="ftab" onclick="setFilter('correction',this)">Corrections</button>
    <button class="ftab" onclick="setFilter('new-word',this)">New Words</button>
    <button class="ftab" onclick="setFilter('dialect',this)">Dialect</button>
  </div>

  <!-- LIST -->
  <div class="fb-list" id="fb-list"></div>
  <div class="empty-state" id="empty-state" style="display:none">
    <h3>No feedback entries yet</h3>
    <p>When you receive feedback by email, paste it using the form above.</p>
  </div>
</div>

<script>
const STORAGE_KEY = 'bahasa_kitani_feedback';
let currentFilter = 'all';

function load() {
  try { return JSON.parse(localStorage.getItem(STORAGE_KEY)) || []; }
  catch(e) { return []; }
}
function save(data) { localStorage.setItem(STORAGE_KEY, JSON.stringify(data)); }

function addEntry() {
  const name    = document.getElementById('a-name').value.trim() || 'Anonymous';
  const email   = document.getElementById('a-email').value.trim() || '';
  const type    = document.getElementById('a-type').value;
  const message = document.getElementById('a-message').value.trim();
  if (!message) { alert('Please paste the feedback message.'); return; }
  const data = load();
  data.unshift({ id: Date.now(), name, email, type, message, resolved: false, date: new Date().toLocaleDateString('en-GB',{day:'numeric',month:'short',year:'numeric'}) });
  save(data);
  ['a-name','a-email','a-message'].forEach(id => document.getElementById(id).value = '');
  document.getElementById('a-type').value = 'correction';
  render();
}

function resolve(id) {
  const data = load();
  const item = data.find(x => x.id === id);
  if (item) { item.resolved = true; save(data); render(); }
}
function restore(id) {
  const data = load();
  const item = data.find(x => x.id === id);
  if (item) { item.resolved = false; save(data); render(); }
}
function remove(id) {
  if (!confirm('Delete this feedback entry?')) return;
  save(load().filter(x => x.id !== id));
  render();
}

function setFilter(f, btn) {
  currentFilter = f;
  document.querySelectorAll('.ftab').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  render();
}

const typeLabels = { correction:'Correction', 'new-word':'New Word', dialect:'Dialect Variant', general:'General' };
const typeClass  = { correction:'type-correction', 'new-word':'type-new-word', dialect:'type-dialect', general:'type-general' };

function render() {
  const all = load();
  const total    = all.length;
  const open     = all.filter(x => !x.resolved).length;
  const resolved = all.filter(x => x.resolved).length;
  document.getElementById('stat-total').textContent    = total;
  document.getElementById('stat-open').textContent     = open;
  document.getElementById('stat-resolved').textContent = resolved;

  let filtered = all;
  if (currentFilter === 'open')     filtered = all.filter(x => !x.resolved);
  if (currentFilter === 'resolved') filtered = all.filter(x => x.resolved);
  if (['correction','new-word','dialect','general'].includes(currentFilter)) filtered = all.filter(x => x.type === currentFilter);

  const list = document.getElementById('fb-list');
  const empty = document.getElementById('empty-state');

  if (filtered.length === 0) { list.innerHTML = ''; empty.style.display = 'block'; return; }
  empty.style.display = 'none';

  list.innerHTML = filtered.map(item => `
    <div class="fb-item ${item.resolved ? 'resolved' : ''}">
      <div>
        <div class="fb-meta">
          <span class="fb-type-tag ${typeClass[item.type]}">${typeLabels[item.type]}</span>
          <span class="fb-name">${item.name}</span>
          ${item.email ? `<span class="fb-email">${item.email}</span>` : ''}
          ${item.resolved ? '<span class="resolved-badge">✓ Resolved</span>' : ''}
          <span class="fb-date">${item.date}</span>
        </div>
        <div class="fb-message">${item.message}</div>
      </div>
      <div class="fb-actions">
        ${!item.resolved
          ? `<button class="action-btn resolve" onclick="resolve(${item.id})">✓ Resolve</button>`
          : `<button class="action-btn restore" onclick="restore(${item.id})">↩ Reopen</button>`}
        <button class="action-btn delete" onclick="remove(${item.id})">🗑 Delete</button>
      </div>
    </div>`).join('');
}

render();
</script>
</body>
</html>
